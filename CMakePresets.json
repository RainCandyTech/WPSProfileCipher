{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-mt-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/triplets",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-mt",
        "WPS_PROFILE_CIPHER_STATIC_MSVC_RUNTIME": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-md-base",
      "hidden": true,
      "inherits": "windows-mt-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "WPS_PROFILE_CIPHER_STATIC_MSVC_RUNTIME": "OFF"
      }
    },
    {
      "name": "windows-x64-mt-debug",
      "displayName": "Windows x64 Debug (/MTd)",
      "inherits": "windows-mt-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-mt-release",
      "displayName": "Windows x64 Release (/MT)",
      "inherits": "windows-mt-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-x86-mt-release",
      "displayName": "Windows x86 Release (/MT)",
      "inherits": "windows-mt-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x86-windows-static-mt"
      }
    },
    {
      "name": "windows-arm64-mt-release",
      "displayName": "Windows arm64 Release (/MT)",
      "inherits": "windows-mt-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "arm64-windows-static-mt"
      }
    },
    {
      "name": "windows-x64-md-debug",
      "displayName": "Windows x64 Debug (/MDd)",
      "inherits": "windows-md-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-x64-md-release",
      "displayName": "Windows x64 Release (/MD)",
      "inherits": "windows-md-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-x86-md-release",
      "displayName": "Windows x86 Release (/MD)",
      "inherits": "windows-md-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x86-windows-static-md"
      }
    },
    {
      "name": "windows-arm64-md-release",
      "displayName": "Windows arm64 Release (/MD)",
      "inherits": "windows-md-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "arm64-windows-static-md"
      }
    },
    {
      "name": "unix-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/cmake/triplets",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "linux-x64-release",
      "displayName": "Linux x64 Release",
      "inherits": "unix-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-arm64-release",
      "displayName": "Linux arm64 Release",
      "inherits": "unix-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-linux"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "macos-x64-release",
      "displayName": "macOS x64 Release",
      "inherits": "unix-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-osx-static"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "macos-arm64-release",
      "displayName": "macOS arm64 Release",
      "inherits": "unix-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx-static"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-mt-debug",
      "configurePreset": "windows-x64-mt-debug"
    },
    {
      "name": "windows-x64-mt-release",
      "configurePreset": "windows-x64-mt-release"
    },
    {
      "name": "windows-x86-mt-release",
      "configurePreset": "windows-x86-mt-release"
    },
    {
      "name": "windows-arm64-mt-release",
      "configurePreset": "windows-arm64-mt-release"
    },
    {
      "name": "windows-x64-md-debug",
      "configurePreset": "windows-x64-md-debug"
    },
    {
      "name": "windows-x64-md-release",
      "configurePreset": "windows-x64-md-release"
    },
    {
      "name": "windows-x86-md-release",
      "configurePreset": "windows-x86-md-release"
    },
    {
      "name": "windows-arm64-md-release",
      "configurePreset": "windows-arm64-md-release"
    },
    {
      "name": "linux-x64-release",
      "configurePreset": "linux-x64-release"
    },
    {
      "name": "linux-arm64-release",
      "configurePreset": "linux-arm64-release"
    },
    {
      "name": "macos-x64-release",
      "configurePreset": "macos-x64-release"
    },
    {
      "name": "macos-arm64-release",
      "configurePreset": "macos-arm64-release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-x64-mt-debug",
      "configurePreset": "windows-x64-mt-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-x64-mt-release",
      "configurePreset": "windows-x64-mt-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-x86-mt-release",
      "configurePreset": "windows-x86-mt-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-arm64-mt-release",
      "configurePreset": "windows-arm64-mt-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-x64-md-debug",
      "configurePreset": "windows-x64-md-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-x64-md-release",
      "configurePreset": "windows-x64-md-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-x86-md-release",
      "configurePreset": "windows-x86-md-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-arm64-md-release",
      "configurePreset": "windows-arm64-md-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-x64-release",
      "configurePreset": "linux-x64-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-arm64-release",
      "configurePreset": "linux-arm64-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-x64-release",
      "configurePreset": "macos-x64-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-arm64-release",
      "configurePreset": "macos-arm64-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
